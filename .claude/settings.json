{
  "respectGitignore": true,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Write(.env)",
      "Write(.env.*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enabledPlugins": {
    "wiggum-util@wiggum": true,
    "wiggum@wiggum": true
  },
  "extraKnownMarketplaces": {
    "wiggum": {
      "source": {
        "source": "github",
        "repo": "hhoikoo/wiggum"
      },
      "autoUpdate": true
    }
  }
}
